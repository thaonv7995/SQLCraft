# ============================================================
# SQLCraft Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- Application ----
NODE_ENV=development
APP_PORT=13029
API_PORT=4000
WORKER_PORT=4001
# API: verbose EXPLAIN row shape on challenge submit (pino info, tag plannerCostDiag)
# Default LOG_LEVEL=info already logs plannerCostWarn when cost stays unknown.
# PLANNER_COST_DEBUG=1

# ---- Database ----
DATABASE_URL=postgresql://sqlcraft:sqlcraft@localhost:5432/sqlcraft
DATABASE_MAX_CONNECTIONS=10

# ---- Redis ----
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=

# ---- Auth ----
JWT_SECRET=change-me-in-production-use-32-char-minimum
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ---- Object Storage (MinIO in dev) ----
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=sqlforge

# ---- Sandbox ----
SANDBOX_DB_HOST=localhost
SANDBOX_DB_PORT=5433
SANDBOX_DB_USER=sandbox
SANDBOX_DB_PASSWORD=sandbox
# SQL Server sandboxes: SA password must be 8+ chars with upper, lower, digit, symbol (not the same as short SANDBOX_DB_PASSWORD).
SANDBOX_MSSQL_SA_PASSWORD=SqlForge1!Sb
SANDBOX_MAX_QUERY_TIME_MS=30000
SANDBOX_MAX_ROWS_PREVIEW=500
SANDBOX_POSTGRES_MAX_WAL_SIZE=4GB
SANDBOX_POSTGRES_MIN_WAL_SIZE=1GB
SANDBOX_POSTGRES_CHECKPOINT_TIMEOUT=30min
SANDBOX_POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9
SANDBOX_POSTGRES_WAL_COMPRESSION=on
SANDBOX_POSTGRES_SYNCHRONOUS_COMMIT=off

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
