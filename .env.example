# ============================================================
# SQLCraft Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- Application ----
NODE_ENV=development
APP_PORT=13029
API_PORT=4000
WORKER_PORT=4001
# API: verbose EXPLAIN row shape on challenge submit (pino info, tag plannerCostDiag)
# Default LOG_LEVEL=info already logs plannerCostWarn when cost stays unknown.
# PLANNER_COST_DEBUG=1

# ---- Database ----
DATABASE_URL=postgresql://sqlcraft:sqlcraft@localhost:5432/sqlcraft
DATABASE_MAX_CONNECTIONS=10

# ---- Redis ----
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=

# ---- Worker (BullMQ) ----
# all = one process (default). sandbox = Docker + provision/cleanup/reset only. query = query-execution only (no Docker).
# Docker Compose dev runs two services: worker (sandbox) + worker-query (query).
# WORKER_ROLE=all
# QUERY_WORKER_CONCURRENCY=4

# ---- Auth ----
JWT_SECRET=change-me-in-production-use-32-char-minimum
JWT_EXPIRES_IN=30m
REFRESH_TOKEN_EXPIRES_DAYS=30

# ---- Object Storage (MinIO in dev) ----
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
# Same default as apps/api `STORAGE_BUCKET` (config) and worker `resolveStorageBucket()`.
STORAGE_BUCKET=sqlcraft
# Worker uploads via `docker exec` + mc inside this container (docker compose dev: sqlcraft-minio).
# STORAGE_DOCKER_CONTAINER=sqlcraft-minio

# ---- Sandbox ----
SANDBOX_DB_HOST=localhost
SANDBOX_DB_PORT=5433
# API host-mode introspection ports when sandbox has no Docker containerRef (defaults match apps/api config).
SANDBOX_MYSQL_PORT=3306
SANDBOX_MSSQL_PORT=1433
SANDBOX_DB_USER=sandbox
SANDBOX_DB_PASSWORD=sandbox
# SQL Server sandboxes: SA password must be 8+ chars with upper, lower, digit, symbol (not the same as short SANDBOX_DB_PASSWORD).
SANDBOX_MSSQL_SA_PASSWORD=SqlForge1!Sb
SANDBOX_MAX_QUERY_TIME_MS=30000
SANDBOX_MAX_ROWS_PREVIEW=500
SANDBOX_POSTGRES_MAX_WAL_SIZE=4GB
SANDBOX_POSTGRES_MIN_WAL_SIZE=1GB
SANDBOX_POSTGRES_CHECKPOINT_TIMEOUT=30min
SANDBOX_POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9
SANDBOX_POSTGRES_WAL_COMPRESSION=on
SANDBOX_POSTGRES_SYNCHRONOUS_COMMIT=off

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ---- AI provider settings ----
# Required to save user AI API keys. Generate with: openssl rand -hex 32
AI_SETTINGS_ENCRYPTION_KEY=
AI_REQUEST_TIMEOUT_MS=180000

# ---- Admin SQL import (POST /v1/admin/databases/scan) ----
# Default ~50 GiB upload cap; max 128 GiB. Large files stream to object storage.
# Full CREATE TABLE scan loads the whole file into RAM (~2× as Buffer + UTF-8 string).
# Default 512 MiB keeps headroom on a 4–8 GiB worker; raise carefully (max 8192).
# Anything > 1.5 GiB is force-flipped to artifact-only regardless of this value.
# SQL_DUMP_MAX_FILE_MB=51200
# SQL_DUMP_FULL_PARSE_MAX_MB=512
# Cap decompressed size for .sql.gz / ZIP inner .sql (default min(8192, 4 × SQL_DUMP_MAX_FILE_MB) MiB)
# SQL_DUMP_MAX_UNCOMPRESSED_MB=8192
# NEXT_PUBLIC_SQL_DUMP_MAX_FILE_MB=51200
# NEXT_PUBLIC_SQL_DUMP_FULL_PARSE_MAX_MB=256

# ---- Background reconcilers (apps/api) ----
# Cadence (ms) of the stale upload-session reconciler (0 disables).
# STALE_UPLOAD_SESSION_INTERVAL_MS=3600000
# Cadence (ms) of the orphan multipart cleanup job (0 disables).
# ORPHAN_MULTIPART_INTERVAL_MS=21600000
# Multipart uploads older than this (ms) are aborted.
# ORPHAN_MULTIPART_MAX_AGE_MS=86400000

# ---- Worker concurrency (services/worker) ----
# Most defaults are 1 (sandbox jobs touch Docker); bump CLEANUP/SCAN higher carefully.
# SANDBOX_PROVISIONING_CONCURRENCY=1
# SANDBOX_CLEANUP_CONCURRENCY=4
# SANDBOX_RESET_CONCURRENCY=1
# DATASET_GOLDEN_BAKE_CONCURRENCY=1
# SQL_DUMP_SCAN_CONCURRENCY=4
# GOLDEN_SNAPSHOT_CANDIDATE_BAKE_CONCURRENCY=1
# Stalled SQL dump scan reconciler (worker side).
# SQL_DUMP_SCAN_RECONCILE_INTERVAL_MS=300000
# SQL_DUMP_SCAN_STALLED_AFTER_MS=900000
# Archived golden snapshot GC.
# GOLDEN_SNAPSHOT_RETENTION_DAYS=30
# ARCHIVED_SNAPSHOT_GC_INTERVAL_MS=86400000
