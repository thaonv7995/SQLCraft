# SQLCraft — Caddy 2 reverse proxy + automatic HTTPS (Let's Encrypt).
#
# 1. Point DNS A/AAAA for your domain to this server.
# 2. Open ports 80 and 443 on the firewall (see docs/deployment-guide.md).
# 3. Replace placeholders and ports if your .env.production differs.
#
# Install Caddy (Debian/Ubuntu example):
#   sudo apt install -y debian-keyring debian-archive-keyring apt-transport-https curl
#   curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' | sudo gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive.gpg
#   curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' | sudo tee /etc/apt/sources.list.d/caddy-stable.list
#   sudo apt update && sudo apt install caddy
#
# Copy this file to /etc/caddy/Caddyfile (or include from main Caddyfile), then:
#   sudo systemctl reload caddy

# Replace this hostname with PUBLIC_DOMAIN (same as in .env.production).
lab.example.com {
	encode zstd gzip

	# API (must stay on same origin as the web app when NEXT_PUBLIC_API_URL=/v1)
	handle /v1/* {
		reverse_proxy 127.0.0.1:4000
	}

	# MinIO bucket path for presigned URLs (bucket default: sqlcraft — match STORAGE_BUCKET)
	handle /sqlcraft/* {
		reverse_proxy 127.0.0.1:9000
	}

	# Next.js app
	handle {
		reverse_proxy 127.0.0.1:13029
	}
}
