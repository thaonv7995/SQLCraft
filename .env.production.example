# Copy to .env.production before running:
#   make prod-build
# (make prod-build will refresh secrets + first admin credentials automatically)

NODE_ENV=production
# Used for container/network names (installer auto-adjusts if this name already exists)
STACK_NAME=sqlcraft

# Prebuilt app images (recommended for faster install)
USE_PREBUILT_IMAGES=true
SQLCRAFT_GHCR_OWNER=thaonv7995
SQLCRAFT_VERSION=latest
API_IMAGE=ghcr.io/thaonv7995/sqlcraft-api:latest
WEB_IMAGE=ghcr.io/thaonv7995/sqlcraft-web:latest
WORKER_IMAGE=ghcr.io/thaonv7995/sqlcraft-worker:latest

# ---- Service ports on host ----
# Bind controls default exposure (127.0.0.1 = local only, 0.0.0.0 = public)
WEB_BIND=0.0.0.0
API_BIND=127.0.0.1
POSTGRES_BIND=127.0.0.1
REDIS_BIND=127.0.0.1
MINIO_API_BIND=127.0.0.1
MINIO_CONSOLE_BIND=127.0.0.1
WEB_PORT=13029
API_PORT=4000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- URLs inside the Compose network (service names: postgres, redis, minio) ----
POSTGRES_USER=sqlcraft
POSTGRES_DB=sqlcraft
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://sqlcraft:change-me@postgres:5432/sqlcraft
REDIS_URL=redis://redis:6379
QUEUE_PREFIX=sqlcraft:prod

# ---- App secrets (auto-generated by make prod-setup / prod-build) ----
JWT_SECRET=change-me
JWT_EXPIRES_IN=30m
REFRESH_TOKEN_EXPIRES_DAYS=30

# ---- First admin credentials (used by seed script) ----
FIRST_ADMIN_EMAIL=admin@sqlcraft.local
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=change-me

# ---- Object storage ----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
STORAGE_ENDPOINT=http://minio:9000
STORAGE_PUBLIC_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=change-me
STORAGE_BUCKET=sqlcraft

# ---- Sandbox (API + worker). Network name should match "${STACK_NAME}-prod" ----
SANDBOX_DB_HOST=host.docker.internal
SANDBOX_DB_PORT=5433
SANDBOX_MYSQL_PORT=3306
SANDBOX_MSSQL_PORT=1433
SANDBOX_DB_USER=sandbox
SANDBOX_DB_PASSWORD=change-me
SANDBOX_DOCKER_NETWORK=sqlcraft-prod

# Browser URLs
PUBLIC_DOMAIN=localhost
NEXT_PUBLIC_APP_URL=http://localhost:13029
NEXT_PUBLIC_API_URL=/v1
NEXT_INTERNAL_API_ORIGIN=http://api:4000
ALLOWED_ORIGINS=http://localhost:13029

# ---- AI provider settings ----
# Required to save user AI API keys. Generate with: openssl rand -hex 32
AI_SETTINGS_ENCRYPTION_KEY=
AI_REQUEST_TIMEOUT_MS=30000

# Override image tags if needed (example)
# SQLCRAFT_GHCR_OWNER=your-org
# SQLCRAFT_VERSION=v1.0.0
