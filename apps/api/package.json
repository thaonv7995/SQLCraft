{
  "name": "@sqlcraft/api",
  "version": "0.1.6",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:bootstrap": "tsx src/db/bootstrap.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@sqlcraft/sandbox-schema-diff": "workspace:*",
    "@sqlcraft/sql-dump-parser": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.1",
    "@sqlcraft/types": "workspace:*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.7.0",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.21.0",
    "drizzle-orm": "^0.30.0",
    "fastify": "^4.27.0",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.3.2",
    "minio": "^8.0.7",
    "mssql": "^11.0.1",
    "mysql2": "^3.11.0",
    "pg": "^8.11.5",
    "pino": "^9.1.0",
    "pino-pretty": "^11.0.0",
    "unzipper": "^0.12.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/mssql": "^9.1.11",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.5",
    "@types/unzipper": "^0.10.11",
    "globals": "^17.4.0",
    "tsx": "^4.9.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^1.5.0"
  }
}
